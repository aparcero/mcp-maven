# Transport
TRANSPORT=stdio

# Maven Central
MAVEN_CENTRAL_URL=https://repo1.maven.org/maven2
MAVEN_TIMEOUT=10s
MAVEN_MAX_RESULTS=100

# Cache
CACHE_ALL_VERSIONS_TTL=1h
CACHE_VERSION_CHECKS_TTL=6h
CACHE_HISTORICAL_DATA_TTL=24h
CACHE_TIMESTAMP_TTL=24h
CACHE_MAX_SIZE=10000

# Logging
LOG_LEVEL=info
LOG_FORMAT=text

# HTTP transport
HTTP_PORT=8080

# Batch limits
MAX_CONCURRENT_REQUESTS=8
MAX_DEPENDENCIES=100

# Context7 documentation integration
CONTEXT7_ENABLED=false
CONTEXT7_API_KEY=
CONTEXT7_SERVER_URL=https://context7.com
CONTEXT7_TIMEOUT=30s

# Reserved for future metrics support
METRICS_ENABLED=false
